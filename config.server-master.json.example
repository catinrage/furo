{
  "namespace": "default",
  "api_key": "my_super_secret_123456789",
  "listen": "0.0.0.0:19082",
  "public_url": "http://MASTER_PUBLIC_IP:19082",
  "admin_listen": "127.0.0.1:19083",
  "caasify_token": "your-caasify-token",
  "state_file": "furo-server-master-default-state.json",
  "log_file": "./furo-server-master-default.log",
  "relay_url": "https://example.com/furo-relay.php",
  "relay_health_host": "f2.ra1n.xyz",
  "relay_health_port": 443,
  "server_agent_port": 8443,
  "route_session_count": 4,
  "backup_count": 1,
  "node_check_interval_seconds": 10,
  "node_failure_threshold": 3,
  "publish_interval_seconds": 60,
  "product_id": 3776,
  "template": "ubuntu-24.04",
  "note_prefix": "furo-server",
  "ipv4": 1,
  "ipv6": 1,
  "bootstrap_script_path": "scripts/bootstrap-server-node.sh.example"
}
