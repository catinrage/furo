{
  "namespace": "default",
  "api_key": "my_super_secret_123456789",
  "listen": "0.0.0.0:19082",
  "public_url": "http://MASTER_PUBLIC_IP:19082",
  "admin_listen": "127.0.0.1:19083",
  "provider_backend": "doprax",
  "doprax_api_key": "your-doprax-v1-api-key",
  "doprax_username": "your-doprax-login-email",
  "doprax_password": "your-doprax-login-password",
  "doprax_base_url": "https://www.doprax.com",
  "doprax_product_version_id": "4034ee51-9731-4663-95ee-a162dc47b119",
  "doprax_location_option_id": "ec5bc1aa-db5f-48a8-8d88-ef654a2a6dc8",
  "doprax_os_option_id": "ec9473a2-caa6-4197-95a4-7ee7e2b59dba",
  "doprax_access_method": "password",
  "doprax_login_retry_attempts": 3,
  "doprax_login_retry_delay_seconds": 5,
  "caasify_token": "",
  "static_egress": {
    "enabled": false,
    "interface": "wg-furo",
    "listen_port": 51820,
    "subnet": "10.66.0.0/24",
    "master_tunnel_ip": "10.66.0.1",
    "node_route_table": 51820,
    "node_route_priority": 1000,
    "auto_install_packages": true
  },
  "state_file": "furo-server-master-default-state.json",
