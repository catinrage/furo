#!/usr/bin/env bash
set -euo pipefail

REPO="${FURO_UPDATE_REPO:-catinrage/furo}"
API_URL="https://api.github.com/repos/${REPO}/releases"
WORKDIR="/root/furo"

require() {
  command -v "$1" >/dev/null 2>&1 || {
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y "$1"
  }
}

require curl
require tar
require python3

STATIC_EGRESS_ENABLED="{{static_egress_enabled}}"
WG_INTERFACE="{{wg_interface}}"
WG_NODE_PRIVATE_KEY="{{wg_node_private_key}}"
WG_NODE_TUNNEL_IP="{{wg_node_tunnel_ip}}"
WG_NODE_TUNNEL_PREFIX="{{wg_node_tunnel_prefix}}"
WG_MASTER_PUBLIC_KEY="{{wg_master_public_key}}"
WG_MASTER_ENDPOINT_HOST="{{wg_master_endpoint_host}}"
WG_MASTER_LISTEN_PORT="{{wg_master_listen_port}}"
WG_NODE_ROUTE_TABLE="{{wg_node_route_table}}"

if [ "$STATIC_EGRESS_ENABLED" = "true" ]; then
  if ! command -v ip >/dev/null 2>&1 || ! command -v iptables >/dev/null 2>&1 || ! command -v wg >/dev/null 2>&1 || ! command -v wg-quick >/dev/null 2>&1; then
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y wireguard-tools iproute2 iptables
  fi
fi

echo "[bootstrap] preparing workdir: $WORKDIR"
mkdir -p "$WORKDIR"
cd "$WORKDIR"

echo "[bootstrap] checking latest release from $API_URL"
python3 - "$API_URL" > /tmp/furo-release.tsv <<'PY'
import json
import sys
import urllib.request

url = sys.argv[1]
with urllib.request.urlopen(url, timeout=30) as resp:
    releases = json.load(resp)

for release in releases:
    if release.get("draft"):
        continue
    for asset in release.get("assets", []):
        name = asset.get("name") or ""
        if name.endswith("_linux_amd64.tar.gz"):
            print(name + "\t" + asset["browser_download_url"])
            raise SystemExit(0)
raise SystemExit("no linux amd64 release asset found")
PY

ARCHIVE="$(cut -f1 /tmp/furo-release.tsv)"
URL="$(cut -f2 /tmp/furo-release.tsv)"
echo "[bootstrap] downloading release: $ARCHIVE"
curl -fsSL -o "$ARCHIVE" "$URL"
echo "[bootstrap] extracting release"
rm -rf /tmp/furo-extract
mkdir -p /tmp/furo-extract
tar -xzf "$ARCHIVE" -C /tmp/furo-extract
RELEASE_ROOT="$(find /tmp/furo-extract -mindepth 1 -maxdepth 1 -type d | head -n1)"
cp -a "$RELEASE_ROOT"/. "$WORKDIR"/

echo "[bootstrap] writing server config"
cat > "$WORKDIR/config.server.json" <<EOF
{
  "api_key": "{{api_key}}",
  "agent_listen": "0.0.0.0:{{server_agent_port}}",
  "admin_listen": "127.0.0.1:19081",
  "dial_timeout": "10s",
  "keepalive": "30s",
  "write_timeout": "30s",
  "frame_min_size": 32768,
  "frame_mid_size": 65536,
  "frame_max_size": 131072,
  "max_pending_bytes": 4194304,
  "max_sessions": 33,
  "log_file": "",
  "egress": {
    "enabled": {{static_egress_enabled}},
    "bind_ip": "{{wg_node_tunnel_ip}}"
  },
  "node": {
    "enabled": true,
    "namespace": "{{namespace}}",
    "id": "{{node_id}}",
    "master_url": "{{master_url}}",
    "role": "{{node_role}}",
    "relay_health_host": "{{relay_health_host}}",
    "relay_health_port": {{relay_health_port}},
    "check_interval_seconds": {{check_interval_seconds}},
    "failure_threshold": {{failure_threshold}}
  }
}
EOF

if [ "$STATIC_EGRESS_ENABLED" = "true" ]; then
  echo "[bootstrap] configuring static egress WireGuard"
  mkdir -p /etc/wireguard
  chmod 700 /etc/wireguard
  cat > "/etc/wireguard/${WG_INTERFACE}.conf" <<EOF
[Interface]
PrivateKey = ${WG_NODE_PRIVATE_KEY}
Address = ${WG_NODE_TUNNEL_IP}/${WG_NODE_TUNNEL_PREFIX}
Table = off
PostUp = ip route replace default dev %i table ${WG_NODE_ROUTE_TABLE}; ip rule add from ${WG_NODE_TUNNEL_IP}/32 table ${WG_NODE_ROUTE_TABLE} priority ${WG_NODE_ROUTE_TABLE} 2>/dev/null || true
PostDown = ip rule del from ${WG_NODE_TUNNEL_IP}/32 table ${WG_NODE_ROUTE_TABLE} priority ${WG_NODE_ROUTE_TABLE} 2>/dev/null || true; ip route del default dev %i table ${WG_NODE_ROUTE_TABLE} 2>/dev/null || true

[Peer]
PublicKey = ${WG_MASTER_PUBLIC_KEY}
Endpoint = ${WG_MASTER_ENDPOINT_HOST}:${WG_MASTER_LISTEN_PORT}
AllowedIPs = 0.0.0.0/0
PersistentKeepalive = 25
EOF
  chmod 600 "/etc/wireguard/${WG_INTERFACE}.conf"
  systemctl enable "wg-quick@${WG_INTERFACE}" || true
  systemctl restart "wg-quick@${WG_INTERFACE}"
fi

echo "[bootstrap] installing furo-server service"
chmod +x "$WORKDIR/service.sh" "$WORKDIR/furo-server"
FURO_SERVICE_NONINTERACTIVE=1 "$WORKDIR/service.sh" init server
echo "[bootstrap] running update"
"$WORKDIR/service.sh" update --force || true
echo "[bootstrap] restarting service"
"$WORKDIR/service.sh" restart
echo "[bootstrap] done"
